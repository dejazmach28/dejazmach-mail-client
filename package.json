{
  "name": "dejazmach-mail-client",
  "version": "0.1.0",
  "private": true,
  "description": "DejAzmach desktop mail client with a transparent, security-first UI.",
  "homepage": "https://dejazmach.app",
  "author": {
    "name": "DejAzmach",
    "email": "hello@dejazmach.app"
  },
  "license": "UNLICENSED",
  "main": "dist-electron/electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "npm run build:electron && concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\" \"npm:dev:app\"",
    "dev:renderer": "vite",
    "reset:electron-runtime": "node scripts/reset-electron-runtime.cjs",
    "dev:electron": "tsc -p tsconfig.node.json --watch --preserveWatchOutput",
    "dev:app": "wait-on tcp:5173 file:dist-electron/electron/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 node scripts/launch-electron.cjs dist-electron/electron/main.js",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.node.json && npm run reset:electron-runtime",
    "preview": "vite preview",
    "start": "node scripts/launch-electron.cjs dist-electron/electron/main.js",
    "test": "npm run build:electron && node --test dist-electron/electron/*.test.js",
    "ci": "npm run typecheck && npm run test && npm run build",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.dejazmach.mail",
    "productName": "DejAzmach",
    "asar": true,
    "compression": "maximum",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "linux": {
      "icon": "icons/256x256.png",
      "maintainer": "DejAzmach <hello@dejazmach.app>",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "Network"
    },
    "deb": {
      "afterInstall": "build/linux/postinst.sh",
      "afterRemove": "build/linux/postrm.sh"
    },
    "win": {
      "icon": "icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "icons/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.1.4",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.3",
    "vite": "^5.4.18",
    "wait-on": "^8.0.3"
  }
}
