{
  "name": "dejazmach-mail-client",
  "version": "0.1.0",
  "private": true,
  "description": "DejAzmach desktop mail client with a transparent, security-first UI.",
  "main": "dist-electron/electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\" \"npm:dev:app\"",
    "dev:renderer": "vite",
    "dev:electron": "tsc -p tsconfig.node.json --watch --preserveWatchOutput",
    "dev:app": "wait-on tcp:5173 file:dist-electron/electron/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.node.json",
    "preview": "vite preview",
    "start": "electron .",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.dejazmach.mail",
    "productName": "DejAzmach",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.1.4",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.3",
    "vite": "^5.4.18",
    "wait-on": "^8.0.3"
  }
}
